{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    
    "technicians": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && (auth.uid == $uid || root.child('technicians').child(auth.uid).exists())"
      }
    },
    
    "bookings": {
      "$bookingId": {
        ".read": "auth != null && (auth.uid == data.child('userId').val() || root.child('technicians').child(auth.uid).exists())",
        ".write": "auth != null && (auth.uid == data.child('userId').val() || root.child('technicians').child(auth.uid).exists() || !data.exists())"
      }
    },
    
    "pincode_map": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('technicians').child(auth.uid).exists()"
    },
    
    "reject_log": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('technicians').child(auth.uid).exists()"
    }
  }
}