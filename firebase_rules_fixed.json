{
  "rules": {
    "users": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$uid": {
        ".read": "auth != null",
        ".write": "$uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin'",
        ".validate": "newData.hasChildren(['uid', 'name', 'email', 'mobile', 'role'])"
      }
    },
    "coins": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId",
        "balance": {
          ".read": "auth != null && auth.uid === $userId",
          ".write": "auth != null && auth.uid === $userId"
        },
        "transactions": {
          "$txnId": {
            ".read": "auth != null && auth.uid === $userId",
            ".write": "auth != null && auth.uid === $userId"
          }
        }
      }
    },
    "technicians": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$uid": {
        ".read": "auth != null",
        ".write": "$uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin'",
        ".validate": "newData.hasChildren(['uid', 'name', 'email', 'mobile', 'city', 'specializations'])"
      },
      ".indexOn": ["city", "isOnline", "rating"]
    },
    "bookings": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$bookingId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['userId', 'service', 'status', 'createdAt'])"
      },
      ".indexOn": ["userId", "technicianId", "status", "createdAt", "city"]
    },
    "wallet_transactions": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$transactionId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['technicianId', 'type', 'amount', 'timestamp'])"
      },
      ".indexOn": ["technicianId", "timestamp", "type"]
    },
    "payouts": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$payoutId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['technicianId', 'amount', 'status', 'requestedAt'])"
      },
      ".indexOn": ["technicianId", "status", "requestedAt"]
    },
    "services": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$serviceId": {
        ".validate": "newData.hasChildren(['name', 'category', 'basePrice', 'isActive'])"
      },
      ".indexOn": ["category", "isActive"]
    },
    "complaints": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$complaintId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['userId', 'bookingId', 'description', 'status', 'createdAt'])"
      },
      ".indexOn": ["userId", "technicianId", "bookingId", "status", "createdAt"]
    },
    "coupons": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$couponId": {
        ".validate": "newData.hasChildren(['code', 'discountType', 'discountValue', 'isActive'])"
      },
      ".indexOn": ["code", "isActive", "expiryDate"]
    },
    "payments": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$paymentId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['userId', 'bookingId', 'amount', 'status', 'timestamp'])"
      },
      ".indexOn": ["userId", "bookingId", "status", "timestamp", "razorpayOrderId"]
    },
    "reviews": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$reviewId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['userId', 'technicianId', 'bookingId', 'rating', 'createdAt'])",
        "rating": {
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 5"
        }
      },
      ".indexOn": ["userId", "technicianId", "bookingId", "rating", "createdAt"]
    },
    "notifications": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$notificationId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['userId', 'title', 'message', 'timestamp'])"
      },
      ".indexOn": ["userId", "timestamp", "isRead"]
    },
    "settings": {
      ".read": "auth != null",
      ".write": "auth != null",
      "app_config": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "commission": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['percentage', 'updatedAt'])"
      },
      "visiting_charges": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['standard', 'premium', 'updatedAt'])"
      },
      "gst_rate": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
      }
    },
    "analytics": {
      ".read": "auth != null",
      ".write": "auth != null",
      "daily_stats": {
        ".indexOn": ["date"]
      },
      "monthly_stats": {
        ".indexOn": ["month", "year"]
      }
    },
    "chats": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$chatId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "messages": {
          "$messageId": {
            ".validate": "newData.hasChildren(['senderId', 'message', 'timestamp'])"
          }
        }
      },
      ".indexOn": ["userId", "technicianId", "lastMessageAt"]
    },
    "emergency_bookings": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$bookingId": {
        ".validate": "newData.hasChildren(['userId', 'service', 'urgency', 'createdAt'])"
      },
      ".indexOn": ["userId", "status", "urgency", "createdAt"]
    },
    "pincode_map": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "reject_log": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}